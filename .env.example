DEEPGRAM_API_KEY=your_deepgram_api_key
# OpenAI translation is currently disabled. Keep this unset unless translation is re-enabled.
OPENAI_API_KEY=
# Set this to your deployed Railway/Render URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Railway and Render inject PORT automatically in production.
PORT=3000
DEEPGRAM_MODEL=nova-3
DEEPGRAM_ENDPOINTING_MS=60
# OpenAI translation settings are ignored while translation is disabled.
OPENAI_TRANSLATION_TIMEOUT_MS=1800
OPENAI_TRANSLATION_MAX_TOKENS=70
